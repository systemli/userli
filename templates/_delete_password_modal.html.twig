{#
    Reusable password-confirmation modal for delete actions.

    Unlike _confirm_modal.html.twig (which intercepts a form submit and shows a
    simple confirm/cancel dialog), this modal contains a real HTML form with a
    password input field. The form submits directly via POST to the server.

    The form uses the same field names as Symfony's PasswordConfirmationType, so
    the existing POST controller handlers can process it without changes.

    Usage:
        Wrap your page content and this include in a single element with
        `data-controller="modal"`. Each delete trigger button should use:

            data-action="modal#open"

        For pages with multiple deletable items (e.g. aliases), pass the
        form action dynamically:

            data-action="modal#open"
            data-modal-action-param="{{ path('alias_delete_submit', {id: alias.id}) }}"

    Customization (via `with`):
        - modal_title:          Translated title text
        - modal_description:    Translated description/warning text
        - modal_action:         Static form action URL (omit when using dynamic action param)
        - modal_submit_label:   Translated submit button label
        - modal_password_label: Translated password field label (default: 'form.delete-password'|trans)
        - modal_id:             Unique ID for aria-labelledby (default: 'delete-password-modal-title')
        - controller_name:      Stimulus controller name (default: 'modal') — use 'delete-modal'
                                when a second modal controller instance is needed on the same page
#}
{% set ctrl = controller_name|default('modal') %}
{% set modal_id = modal_id|default('delete-password-modal-title') %}
{% set modal_password_label = modal_password_label|default('form.delete-password'|trans) %}

<div data-{{ ctrl }}-target="overlay"
     data-action="click->{{ ctrl }}#backdropClose"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-200"
     aria-modal="true"
     role="dialog"
     aria-labelledby="{{ modal_id }}">

    <div data-{{ ctrl }}-target="dialog"
         class="relative w-full max-w-md mx-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-xl opacity-0 scale-95 transition-all duration-200 transform">

        <div class="p-6 sm:p-8">
            {# Modal header #}
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center">
                    <div class="w-10 h-10 bg-red-100 dark:bg-red-900/50 rounded-xl flex items-center justify-center mr-3">
                        {{ ux_icon('heroicons:exclamation-triangle', {'class': 'w-5 h-5 text-red-600 dark:text-red-400'}) }}
                    </div>
                    <h3 id="{{ modal_id }}"
                        class="text-lg font-semibold text-gray-900 dark:text-gray-100">
                        {{ modal_title }}
                    </h3>
                </div>
                <button type="button"
                        data-action="{{ ctrl }}#close"
                        class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors duration-200">
                    {{ ux_icon('heroicons:x-mark', {'class': 'w-5 h-5'}) }}
                </button>
            </div>

            {# Description #}
            <p data-{{ ctrl }}-target="description"
               class="text-sm text-gray-600 dark:text-gray-400 mb-6">
                {{ modal_description }}
            </p>

            {# Password form #}
            <form method="post"
                  action="{{ modal_action|default('') }}"
                  data-{{ ctrl }}-target="form"
                  class="space-y-6">
                <input type="hidden" name="password_confirmation[_token]" value="{{ csrf_token('password_confirmation') }}">

                <div>
                    <label for="{{ modal_id }}-password"
                           class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        {{ modal_password_label }}
                    </label>
                    <input type="password"
                           id="{{ modal_id }}-password"
                           name="password_confirmation[password]"
                           required
                           data-{{ ctrl }}-target="autofocus"
                           class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400 transition-colors duration-200 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500">
                </div>

                <div class="flex justify-end gap-3">
                    <button type="button"
                            data-action="{{ ctrl }}#close"
                            class="px-5 py-2.5 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
                        {{ "delete.cancel"|trans }}
                    </button>
                    <button type="submit"
                            class="px-5 py-2.5 bg-red-600 dark:bg-red-500 hover:bg-red-700 dark:hover:bg-red-600 text-white font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
                        {{ modal_submit_label }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
