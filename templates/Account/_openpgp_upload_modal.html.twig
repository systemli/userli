{#
    Two-step upload flow for OpenPGP key management.

    Step 1 (uploadOverlay): choose key file or paste key text.
    Step 2 (passwordOverlay): confirm account password — only shown when
                              replacing an existing key. Visually distinct
                              from step 1 so it cannot be confused with the
                              OpenPGP key's own passphrase.

    Variables:
        form – The OpenPgpKeyType form instance
#}
{% form_theme form 'Form/fields.html.twig' %}

{{ form_start(form, {'attr': {'data-openpgp-upload-target': 'form', 'class': 'contents'}}) }}

    {# Hidden fields – always part of the submitted form, regardless of which overlay is visible. #}
    {{ form_widget(form.email, {'attr': {'data-openpgp-upload-target': 'emailField'}}) }}

    {# ── Step 1: key upload ─────────────────────────────── #}
    <div data-openpgp-upload-target="uploadOverlay"
         data-action="click->openpgp-upload#backdropCloseUpload"
         class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-200"
         aria-modal="true"
         role="dialog"
         aria-labelledby="openpgp-upload-title">

        <div data-openpgp-upload-target="uploadDialog"
             class="relative w-full max-w-lg mx-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-xl opacity-0 scale-95 transition-all duration-200 transform">

            <div class="p-6 sm:p-8">
                <div class="flex items-center justify-between mb-6">
                    <div class="flex items-center">
                        <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/50 rounded-xl flex items-center justify-center mr-3">
                            {{ ux_icon('heroicons:cloud-arrow-up', {'class': 'w-5 h-5 text-blue-600 dark:text-blue-400'}) }}
                        </div>
                        <div>
                            <h3 id="openpgp-upload-title" class="text-lg font-semibold text-gray-900 dark:text-gray-100">{{ "openpgp.upload-modal-title"|trans }}</h3>
                            <p class="text-sm text-gray-500 dark:text-gray-400">
                                {{ "openpgp.upload-for"|trans }}
                                <span data-openpgp-upload-target="title" class="font-medium text-gray-700 dark:text-gray-300 font-mono"></span>
                            </p>
                        </div>
                    </div>
                    <button type="button"
                            data-action="openpgp-upload#close"
                            class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors duration-200">
                        {{ ux_icon('heroicons:x-mark', {'class': 'w-5 h-5'}) }}
                    </button>
                </div>

                {% if form.vars.errors|length > 0 %}
                    <div class="bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 rounded-lg p-4 mb-4" role="alert">
                        <div class="flex">
                            {{ ux_icon('heroicons:x-circle-20-solid', {'class': 'w-5 h-5 text-red-400 dark:text-red-500 mt-0.5 mr-3 flex-shrink-0'}) }}
                            <div class="text-sm text-red-700 dark:text-red-200">
                                {% for error in form.vars.errors %}
                                    <p class="{% if not loop.last %}mb-2{% endif %}">{{ error.message }}</p>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}

                <div class="space-y-5">
                    <div>
                        {{ form_label(form.keyFile, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2'}}) }}
                        {% if form.keyFile.vars.errors|length > 0 %}
                            <div class="text-sm text-red-600 dark:text-red-400 mb-2">
                                {% for error in form.keyFile.vars.errors %}
                                    <p class="{% if not loop.last %}mb-1{% endif %}">{{ error.message }}</p>
                                {% endfor %}
                            </div>
                        {% endif %}
                        {{ form_widget(form.keyFile, {'attr': {'class': 'block w-full text-sm text-gray-900 dark:text-gray-100 border border-gray-300 dark:border-gray-600 rounded-lg cursor-pointer bg-gray-50 dark:bg-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent p-3 transition-colors duration-200'}}) }}
                    </div>

                    <div class="text-center">
                        <span class="inline-flex items-center px-3 py-1 text-sm text-gray-500 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 rounded-full">
                            {{ "openpgp-key-upload-or"|trans }}
                        </span>
                    </div>

                    <div>
                        {{ form_label(form.keyText, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2'}}) }}
                        {% if form.keyText.vars.errors|length > 0 %}
                            <div class="text-sm text-red-600 dark:text-red-400 mb-2">
                                {% for error in form.keyText.vars.errors %}
                                    <p class="{% if not loop.last %}mb-1{% endif %}">{{ error.message }}</p>
                                {% endfor %}
                            </div>
                        {% endif %}
                        {{ form_widget(form.keyText, {'attr': {'class': 'block w-full px-3 py-3 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 font-mono text-sm transition-colors duration-200', 'rows': '8', 'placeholder': 'openpgp-key-text-placeholder'|trans}}) }}
                    </div>

                    <div class="flex justify-end gap-3 pt-2">
                        <button type="button"
                                data-action="openpgp-upload#close"
                                class="px-5 py-2.5 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
                            {{ "delete.cancel"|trans }}
                        </button>
                        <button type="button"
                                data-action="openpgp-upload#advance"
                                class="px-5 py-2.5 bg-blue-600 dark:bg-blue-500 hover:bg-blue-700 dark:hover:bg-blue-600 text-white font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
                            {{ "openpgp.upload-modal-continue"|trans }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Step 2: account password confirmation ─────────── #}
    <div data-openpgp-upload-target="passwordOverlay"
         data-action="click->openpgp-upload#backdropClosePassword"
         class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-200"
         aria-modal="true"
         role="dialog"
         aria-labelledby="openpgp-replace-title">

        <div data-openpgp-upload-target="passwordDialog"
             class="relative w-full max-w-md mx-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-xl opacity-0 scale-95 transition-all duration-200 transform">

            <div class="p-6 sm:p-8">
                <div class="flex items-center justify-between mb-4">
                    <div class="flex items-center">
                        <div class="w-10 h-10 bg-amber-100 dark:bg-amber-900/50 rounded-xl flex items-center justify-center mr-3">
                            {{ ux_icon('heroicons:shield-exclamation', {'class': 'w-5 h-5 text-amber-600 dark:text-amber-400'}) }}
                        </div>
                        <h3 id="openpgp-replace-title"
                            class="text-lg font-semibold text-gray-900 dark:text-gray-100">
                            {{ "openpgp.replace-modal-title"|trans }}
                        </h3>
                    </div>
                    <button type="button"
                            data-action="openpgp-upload#close"
                            class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors duration-200">
                        {{ ux_icon('heroicons:x-mark', {'class': 'w-5 h-5'}) }}
                    </button>
                </div>

                <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
                    {{ "openpgp.replace-modal-description"|trans|raw }}
                    <span data-openpgp-upload-target="passwordEmail" class="font-medium text-gray-800 dark:text-gray-200 font-mono break-all"></span>
                </p>
                <p class="text-xs text-amber-700 dark:text-amber-300 mb-5">
                    {{ "openpgp.replace-modal-hint"|trans }}
                </p>

                <div class="space-y-5">
                    <div>
                        {{ form_label(form.password, 'openpgp.replace-modal-password-label'|trans, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2'}}) }}
                        {% if form.password.vars.errors|length > 0 %}
                            <div class="text-sm text-red-600 dark:text-red-400 mb-2">
                                {% for error in form.password.vars.errors %}
                                    <p class="{% if not loop.last %}mb-1{% endif %}">{{ error.message }}</p>
                                {% endfor %}
                            </div>
                        {% endif %}
                        {{ form_widget(form.password, {'attr': {'class': 'block w-full px-3 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 transition-colors duration-200', 'autocomplete': 'current-password', 'data-openpgp-upload-target': 'passwordField'}}) }}
                    </div>

                    <div class="flex justify-end gap-3 pt-2">
                        <button type="button"
                                data-action="openpgp-upload#back"
                                class="px-5 py-2.5 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
                            {{ "openpgp.replace-modal-back"|trans }}
                        </button>
                        {{ form_widget(form.submit, {'attr': {'class': 'px-5 py-2.5 bg-amber-600 dark:bg-amber-500 hover:bg-amber-700 dark:hover:bg-amber-600 text-white font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800'}}) }}
                    </div>
                </div>
            </div>
        </div>
    </div>

{{ form_end(form) }}
