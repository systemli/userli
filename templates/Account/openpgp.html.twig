{% extends 'base_page.html.twig' %}

{% block title %}{{ setting('app_name') }} - {{ "start.openpgp-settings"|trans }}{% endblock %}

{% block page_title %}{{ "start.openpgp-settings"|trans }}{% endblock %}

{% block page_subtitle %}{{ "openpgp.manage-subtitle"|trans }}{% endblock %}

{% block page_content %}
    <div class="max-w-3xl mx-auto" data-controller="openpgp-upload delete-modal">
        {# Brief information explanation #}
        <div class="mb-8 text-center">
            <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed max-w-3xl mx-auto">
                {{ "openpgp.information-details"|trans|raw }}
            </p>
        </div>

        {# ── Your Email ──────────────────────────────────── #}
        <div class="mb-8">
            <h2 class="flex items-center gap-3 text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4">
                {{ ux_icon('heroicons:user', {'class': 'w-4 h-4'}) }}
                {{ "openpgp.your-email"|trans }}
            </h2>

            {% for identity in identities|filter(i => i.type == 'primary') %}
                {% include 'Account/_openpgp_identity_card.html.twig' with {identity: identity} %}
            {% endfor %}
        </div>

        {# ── Alias Addresses ─────────────────────────────── #}
        {% set alias_identities = identities|filter(i => i.type == 'alias') %}

        {% if alias_identities|length > 0 %}
            <div class="mb-8">
                <h2 class="flex items-center gap-3 text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-4">
                    {{ ux_icon('heroicons:at-symbol', {'class': 'w-4 h-4'}) }}
                    {{ "openpgp.alias-addresses"|trans }}
                </h2>

                <div class="space-y-4">
                    {% for identity in alias_identities %}
                        {% include 'Account/_openpgp_identity_card.html.twig' with {identity: identity} %}
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {# ── Upload Modal ────────────────────────────────── #}
        {% include 'Account/_openpgp_upload_modal.html.twig' %}

        {# ── Delete Modal ────────────────────────────────── #}
        {% include '_delete_password_modal.html.twig' with {
            modal_title: 'delete.openpgp.headline'|trans,
            modal_description: 'delete.openpgp.lead'|trans({'%email%': ''}),
            modal_submit_label: 'openpgp-delete'|trans,
            controller_name: 'delete-modal',
            modal_id: 'delete-openpgp-modal-title',
        } %}
    </div>
{% endblock %}
