{#
    Reusable password verification modal.

    Two rendering modes:

    1. Standalone (default) — the modal contains its own <form method="post"> with
       CSRF token, a password input named `password_confirmation[password]`, and
       a submit button that POSTs to `modal_action`. Used for delete confirmations.

    2. External form — when `external_form_id` is set, no <form> is rendered:
       the password input and submit button are associated with an existing form
       elsewhere on the page via the HTML5 `form` attribute. The caller owns the
       form and is responsible for providing its own CSRF token and action.

    Wrap the page (or a parent element) in a Stimulus controller that exposes
    `open`, `close`, `backdropClose`, and — when the modal is part of a multi-step
    flow — an action name supplied via `secondary_action`. Each delete trigger
    should use `data-action="<ctrl>#open"` with an optional
    `data-<ctrl>-action-param="…"` for forms that need a dynamic action URL.

    Parameters (all translated strings already):
        - modal_title            Headline text
        - modal_description      Explanatory body text
        - modal_hint             Optional secondary hint (e.g. "not the OpenPGP key passphrase")
        - modal_submit_label     Primary button label
        - modal_password_label   Label above the password input  (default: form.delete-password)
        - modal_id               id used for aria-labelledby      (default: password-verification-modal-title)
        - modal_action           URL the standalone form POSTs to (standalone only)
        - controller_name        Stimulus controller identifier  (default: modal)
        - tone                   'danger' (red) or 'warning' (amber) — default: danger
        - external_form_id       When set, skip the inner <form> and reference this form id via `form=…`
        - password_name          Name attribute of the password input
                                 (default depends on mode — `password_confirmation[password]`
                                  for standalone, required when using `external_form_id`)
        - secondary_label        Secondary button label          (default: delete.cancel)
        - secondary_action       Stimulus action for secondary   (default: `<ctrl>#close`)
#}
{% set ctrl = controller_name|default('modal') %}
{% set modal_id = modal_id|default('password-verification-modal-title') %}
{% set modal_password_label = modal_password_label|default('form.delete-password'|trans) %}
{% set modal_hint = modal_hint|default(null) %}
{% set tone = tone|default('danger') %}
{% set external_form_id = external_form_id|default(null) %}
{% set password_name = password_name|default('password_confirmation[password]') %}
{% set secondary_label = secondary_label|default('delete.cancel'|trans) %}
{% set secondary_action = secondary_action|default(ctrl ~ '#close') %}

{% set icon = tone == 'warning' ? 'heroicons:shield-exclamation' : 'heroicons:exclamation-triangle' %}
{% set icon_bg = tone == 'warning' ? 'bg-amber-100 dark:bg-amber-900/50' : 'bg-red-100 dark:bg-red-900/50' %}
{% set icon_color = tone == 'warning' ? 'text-amber-600 dark:text-amber-400' : 'text-red-600 dark:text-red-400' %}
{% set focus_ring = tone == 'warning' ? 'focus:ring-amber-500' : 'focus:ring-blue-500 dark:focus:ring-blue-400' %}
{% set submit_classes = tone == 'warning'
    ? 'bg-amber-600 dark:bg-amber-500 hover:bg-amber-700 dark:hover:bg-amber-600 focus:ring-amber-500'
    : 'bg-red-600 dark:bg-red-500 hover:bg-red-700 dark:hover:bg-red-600 focus:ring-red-500' %}
{% set hint_classes = tone == 'warning'
    ? 'text-amber-700 dark:text-amber-300'
    : 'text-gray-500 dark:text-gray-400' %}

<div data-{{ ctrl }}-target="overlay"
     data-action="click->{{ ctrl }}#backdropClose"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-200"
     aria-modal="true"
     role="dialog"
     aria-labelledby="{{ modal_id }}">

    <div data-{{ ctrl }}-target="dialog"
         class="relative w-full max-w-md mx-4 bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-xl opacity-0 scale-95 transition-all duration-200 transform">

        <div class="p-6 sm:p-8">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center">
                    <div class="w-10 h-10 {{ icon_bg }} rounded-xl flex items-center justify-center mr-3">
                        {{ ux_icon(icon, {'class': 'w-5 h-5 ' ~ icon_color}) }}
                    </div>
                    <h3 id="{{ modal_id }}"
                        class="text-lg font-semibold text-gray-900 dark:text-gray-100">
                        {{ modal_title }}
                    </h3>
                </div>
                <button type="button"
                        data-action="{{ ctrl }}#close"
                        class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors duration-200">
                    {{ ux_icon('heroicons:x-mark', {'class': 'w-5 h-5'}) }}
                </button>
            </div>

            <p data-{{ ctrl }}-target="description"
               class="text-sm text-gray-600 dark:text-gray-400 mb-{{ modal_hint ? '2' : '6' }}">
                {{ modal_description }}
            </p>
            {% if modal_hint %}
                <p class="text-xs {{ hint_classes }} mb-5">{{ modal_hint }}</p>
            {% endif %}

            {% if external_form_id %}
                <div class="space-y-6">
                    <div>
                        <label for="{{ modal_id }}-password"
                               class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            {{ modal_password_label }}
                        </label>
                        <input type="password"
                               id="{{ modal_id }}-password"
                               name="{{ password_name }}"
                               form="{{ external_form_id }}"
                               autocomplete="current-password"
                               data-{{ ctrl }}-target="autofocus"
                               class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 {{ focus_ring }} focus:border-transparent transition-colors duration-200 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500">
                    </div>

                    <div class="flex justify-end gap-3">
                        <button type="button"
                                data-action="{{ secondary_action }}"
                                class="px-5 py-2.5 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
                            {{ secondary_label }}
                        </button>
                        <button type="submit"
                                form="{{ external_form_id }}"
                                class="px-5 py-2.5 {{ submit_classes }} text-white font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
                            {{ modal_submit_label }}
                        </button>
                    </div>
                </div>
            {% else %}
                <form method="post"
                      action="{{ modal_action|default('') }}"
                      data-{{ ctrl }}-target="form"
                      class="space-y-6">
                    <input type="hidden" name="password_confirmation[_token]" value="{{ csrf_token('password_confirmation') }}">

                    <div>
                        <label for="{{ modal_id }}-password"
                               class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                            {{ modal_password_label }}
                        </label>
                        <input type="password"
                               id="{{ modal_id }}-password"
                               name="{{ password_name }}"
                               required
                               autocomplete="current-password"
                               data-{{ ctrl }}-target="autofocus"
                               class="w-full px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 {{ focus_ring }} focus:border-transparent transition-colors duration-200 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500">
                    </div>

                    <div class="flex justify-end gap-3">
                        <button type="button"
                                data-action="{{ secondary_action }}"
                                class="px-5 py-2.5 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 font-medium rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
                            {{ secondary_label }}
                        </button>
                        <button type="submit"
                                class="px-5 py-2.5 {{ submit_classes }} text-white font-medium rounded-lg transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 dark:focus:ring-offset-gray-800">
                            {{ modal_submit_label }}
                        </button>
                    </div>
                </form>
            {% endif %}
        </div>
    </div>
</div>
