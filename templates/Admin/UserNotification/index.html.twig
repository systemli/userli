{% set current_section = 'user-notifications' %}
{% extends 'Admin/base_admin.html.twig' %}
{% block title %}{{ setting('app_name') }} - {{ 'admin.user-notification.title'|trans }}{% endblock %}
{% block admin_content %}
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm">
        <div class="p-6 sm:p-8">
            {% include 'Admin/_section_header.html.twig' with {
                icon: 'heroicons:bell-alert',
                icon_color: 'amber',
                heading_key: 'admin.user-notification.heading',
                description_key: 'admin.user-notification.description',
            } %}

            <div class="mb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="flex items-center gap-2">
                    <label for="type-filter" class="text-sm text-gray-600 dark:text-gray-400">{{ 'admin.user-notification.filter.type'|trans }}:</label>
                    <select id="type-filter"
                            data-controller="navigate"
                            data-action="change->navigate#go"
                            class="px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500">
                        <option value="{{ path('admin_user_notification_index', {search: search}|filter(v => v)) }}"{% if type == '' %} selected{% endif %}>{{ 'admin.user-notification.filter.all'|trans }}</option>
                        {% for notificationType in notificationTypes %}
                            <option value="{{ path('admin_user_notification_index', {search: search, type: notificationType.value}|filter(v => v)) }}"{% if type == notificationType.value %} selected{% endif %}>{{ notificationType.value }}</option>
                        {% endfor %}
                    </select>
                </div>

                <form method="get" action="{{ path('admin_user_notification_index') }}" class="flex items-center gap-2">
                    {% if type %}
                        <input type="hidden" name="type" value="{{ type }}">
                    {% endif %}
                    <div class="relative">
                        <input type="text" name="search" value="{{ search }}"
                               placeholder="{{ 'admin.user-notification.search.placeholder'|trans }}"
                               class="pl-10 pr-4 py-2 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                            {{ ux_icon('heroicons:magnifying-glass', {class: 'w-4 h-4 text-gray-400'}) }}
                        </div>
                    </div>
                    <button type="submit"
                            class="inline-flex items-center px-3 py-2 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors">
                        {{ 'admin.user-notification.search.submit'|trans }}
                    </button>
                    {% if search %}
                        <a href="{{ path('admin_user_notification_index', {type: type}|filter(v => v)) }}"
                           class="inline-flex items-center px-3 py-2 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">
                            {{ ux_icon('heroicons:x-mark', {class: 'w-4 h-4'}) }}
                        </a>
                    {% endif %}
                </form>
            </div>

            {% if pagination.items is empty %}
                {% include 'Admin/_empty_state.html.twig' with {
                    icon: 'heroicons:bell-alert',
                    title_key: 'admin.user-notification.table.empty-title',
                    description_key: 'admin.user-notification.table.empty-description',
                } %}
            {% else %}
                {% embed 'Admin/_table.html.twig' with {
                    headers: [
                        {label: 'admin.table.id'},
                        {label: 'admin.user-notification.table.user'},
                        {label: 'admin.user-notification.table.type'},
                        {label: 'admin.table.created'},
                    ]
                } %}
                    {% block table_body %}
                        {% for notification in pagination.items %}
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">{{ notification.id }}</td>
                                <td class="px-4 py-3 text-sm font-mono text-gray-900 dark:text-gray-100">{{ notification.user }}</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 dark:bg-amber-900/50 text-amber-800 dark:text-amber-200">{{ notification.type.value }}</span>
                                </td>
                                <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-300">
                                    {{ notification.creationTime|format_datetime('short', 'short') }}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}

                {% if pagination.totalPages > 1 %}
                    <div class="mt-6 flex items-center justify-between border-t border-gray-200 dark:border-gray-700 pt-4">
                        <div class="text-sm text-gray-500 dark:text-gray-400">
                            {{ 'admin.user-notification.pagination.total'|trans({'%count%': pagination.total}) }}
                        </div>
                        <div class="flex gap-2">
                            {% if pagination.page > 1 %}
                                <a href="{{ path('admin_user_notification_index', {page: pagination.page - 1, search: search, type: type}|filter(v => v)) }}"
                                   class="inline-flex items-center px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">
                                    {{ ux_icon('heroicons:chevron-left', {class: 'w-4 h-4 mr-1'}) }} {{ 'admin.user-notification.pagination.newer'|trans }}
                                </a>
                            {% endif %}
                            <span class="inline-flex items-center px-3 py-1.5 text-sm text-gray-500 dark:text-gray-400">
                                {{ 'admin.user-notification.pagination.page'|trans({'%page%': pagination.page, '%totalPages%': pagination.totalPages}) }}
                            </span>
                            {% if pagination.page < pagination.totalPages %}
                                <a href="{{ path('admin_user_notification_index', {page: pagination.page + 1, search: search, type: type}|filter(v => v)) }}"
                                   class="inline-flex items-center px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">
                                    {{ 'admin.user-notification.pagination.older'|trans }} {{ ux_icon('heroicons:chevron-right', {class: 'w-4 h-4 ml-1'}) }}
                                </a>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            {% endif %}
        </div>
    </div>
{% endblock %}
