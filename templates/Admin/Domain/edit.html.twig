{% set current_section = 'domains' %}
{% extends 'Admin/base_admin.html.twig' %}
{% form_theme form 'Form/fields.html.twig' %}
{% block title %}{{ setting('app_name') }} - {{ domain.name }}{% endblock %}
{% block admin_content %}
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm">
        <div class="p-6 sm:p-8">
            {% include 'Admin/_section_header.html.twig' with {
                icon: 'heroicons:pencil-square',
                icon_color: 'blue',
                heading_key: 'admin.domain.edit.heading',
                description_key: 'admin.domain.edit.description',
            } %}

            <div class="mb-6">
                <p class="text-lg font-semibold text-gray-900 dark:text-gray-100 font-mono">{{ domain.name }}</p>
            </div>

            {{ form_start(form) }}
            {{ form_errors(form) }}

            <div class="space-y-6">
                <div class="flex items-start">
                    <label for="{{ form.invitationEnabled.vars.id }}" class="relative inline-flex items-center cursor-pointer flex-shrink-0 mt-0.5 mr-4">
                        {{ form_widget(form.invitationEnabled, {'attr': {'class': 'sr-only peer'}}) }}
                        <div class="w-11 h-6 bg-gray-200 dark:bg-gray-600 rounded-full peer peer-checked:bg-blue-600 dark:peer-checked:bg-blue-500 peer-focus:ring-2 peer-focus:ring-blue-500 dark:peer-focus:ring-blue-400 peer-focus:ring-offset-2 dark:peer-focus:ring-offset-gray-800 transition-colors duration-200 after:content-[''] after:absolute after:top-0.5 after:start-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all after:duration-200 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full"></div>
                    </label>
                    <div>
                        {{ form_label(form.invitationEnabled, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 cursor-pointer'}}) }}
                        {{ form_help(form.invitationEnabled) }}
                        {{ form_errors(form.invitationEnabled) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.invitationLimit, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2'}}) }}
                    {{ form_errors(form.invitationLimit) }}
                    {{ form_widget(form.invitationLimit, {
                        attr: {
                            class: 'w-32 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400 transition-colors'
                        }
                    }) }}
                    {{ form_help(form.invitationLimit) }}
                </div>

                <div>
                    {{ form_label(form.waitingPeriodDays, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2'}}) }}
                    {{ form_errors(form.waitingPeriodDays) }}
                    {{ form_widget(form.waitingPeriodDays, {
                        attr: {
                            class: 'w-32 px-4 py-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 dark:focus:ring-blue-400 focus:border-blue-500 dark:focus:border-blue-400 transition-colors'
                        }
                    }) }}
                    {{ form_help(form.waitingPeriodDays) }}
                </div>

                <div class="flex items-center justify-between pt-6">
                    <a href="{{ path('admin_domain_show', {id: domain.id}) }}"
                       class="inline-flex items-center px-6 py-3 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800 transition-colors">
                        {{ ux_icon('heroicons:arrow-left', {class: 'w-4 h-4 mr-2'}) }}
                        {{ 'admin.domain.form.cancel'|trans }}
                    </a>
                    {{ form_widget(form.submit, {
                        label: 'admin.domain.edit.submit',
                        attr: {
                            class: 'inline-flex items-center px-6 py-3 bg-blue-600 dark:bg-blue-500 text-white font-medium rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800 transition-colors'
                        }
                    }) }}
                </div>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
