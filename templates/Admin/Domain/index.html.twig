{% set current_section = 'domains' %}
{% extends 'Admin/base_admin.html.twig' %}
{% block title %}{{ setting('app_name') }} - {{ 'admin.domain.title'|trans }}{% endblock %}
{% block admin_content %}
    <div data-controller="modal">
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm">
        <div class="p-6 sm:p-8">
            {% include 'Admin/_section_header.html.twig' with {
                icon: 'heroicons:globe-alt',
                icon_color: 'indigo',
                heading_key: 'admin.domain.heading',
                description_key: 'admin.domain.description',
            } %}

            <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="flex flex-wrap items-center gap-2">
                    <a href="{{ path('admin_domain_create') }}"
                       class="inline-flex items-center px-4 py-2 bg-blue-600 dark:bg-blue-500 text-white font-medium rounded-lg hover:bg-blue-700 dark:hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800 transition-colors">
                        {{ ux_icon('heroicons:plus', {class: 'w-4 h-4 mr-2'}) }}
                        {{ 'admin.domain.create.button'|trans }}
                    </a>
                </div>

                {% include 'Admin/_search_form.html.twig' with {
                    index_route: 'admin_domain_index',
                    placeholder_key: 'admin.domain.search.placeholder',
                    submit_key: 'admin.domain.search.submit',
                    search: search,
                } %}
            </div>

            {% if pagination.items is empty %}
                {% include 'Admin/_empty_state.html.twig' with {
                    icon: 'heroicons:globe-alt',
                    title_key: 'admin.domain.table.empty-title',
                    description_key: 'admin.domain.table.empty-description',
                } %}
            {% else %}
                {% embed 'Admin/_table.html.twig' with {
                    headers: [
                        {label: 'admin.table.id'},
                        {label: 'admin.table.name'},
                        {label: 'admin.table.created'},
                        {label: 'admin.table.actions', align: 'right'},
                    ]
                } %}
                    {% block table_body %}
                        {% for domain in pagination.items %}
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                                <td class="px-4 py-3 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-gray-100">{{ domain.id }}</td>
                                <td class="px-4 py-3 text-sm font-mono text-gray-900 dark:text-gray-100">{{ domain.name }}</td>
                                <td class="px-4 py-3 text-sm text-gray-500 dark:text-gray-300">
                                    {{ domain.creationTime|format_datetime('short', 'short') }}
                                </td>
                                <td class="px-4 py-3 text-right">
                                    <div class="inline-flex items-center gap-1">
                                        <a href="{{ path('admin_domain_show', {id: domain.id}) }}"
                                           title="{{ 'admin.domain.actions.show'|trans }}"
                                           data-controller="tooltip"
                                           class="inline-flex items-center justify-center p-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg transition-colors">
                                            {{ ux_icon('heroicons:eye', {class: 'w-4 h-4'}) }}
                                            <span class="sr-only">{{ 'admin.domain.actions.show'|trans }}</span>
                                        </a>
                                        <button type="button"
                                                data-action="modal#open"
                                                data-modal-action-param="{{ path('admin_domain_delete_post', {id: domain.id}) }}"
                                                data-modal-message-param="{{ 'delete.domain.lead_specific'|trans({'%name%': domain.name}) }}"
                                                title="{{ 'admin.domain.actions.delete'|trans }}"
                                                aria-label="{{ 'admin.domain.actions.delete'|trans }} {{ domain.name }}"
                                                data-controller="tooltip"
                                                class="inline-flex items-center justify-center p-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 border border-gray-200 dark:border-gray-600 rounded-lg transition-colors">
                                            {{ ux_icon('heroicons:trash', {class: 'w-4 h-4'}) }}
                                            <span class="sr-only">{{ 'admin.domain.actions.delete'|trans }}</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endblock %}
                {% endembed %}

                {% include 'Admin/_pagination.html.twig' with {
                    index_route: 'admin_domain_index',
                    total_key: 'admin.domain.pagination.total',
                    previous_key: 'admin.domain.pagination.previous',
                    next_key: 'admin.domain.pagination.next',
                    page_key: 'admin.domain.pagination.page',
                    pagination: pagination,
                    search: search,
                } %}
            {% endif %}
        </div>
    </div>

    {# Delete domain modal #}
    {% include '_delete_password_modal.html.twig' with {
        modal_title: 'delete.domain.headline'|trans,
        modal_description: 'delete.domain.lead_generic'|trans,
        modal_submit_label: 'delete.domain.submit'|trans,
    } %}
    </div>
{% endblock %}
