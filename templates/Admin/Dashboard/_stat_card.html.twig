{# Stat card partial #}
{# Parameters: icon, icon_color, label_key, value, route (optional) #}

{# Map color names to full Tailwind classes so they are detected at build time #}
{% set color_map = {
    blue:   { bg: 'bg-blue-100 dark:bg-blue-900/50',     text: 'text-blue-600 dark:text-blue-400' },
    indigo: { bg: 'bg-indigo-100 dark:bg-indigo-900/50', text: 'text-indigo-600 dark:text-indigo-400' },
    purple: { bg: 'bg-purple-100 dark:bg-purple-900/50', text: 'text-purple-600 dark:text-purple-400' },
    amber:  { bg: 'bg-amber-100 dark:bg-amber-900/50',   text: 'text-amber-600 dark:text-amber-400' },
    green:  { bg: 'bg-green-100 dark:bg-green-900/50',   text: 'text-green-600 dark:text-green-400' },
    orange: { bg: 'bg-orange-100 dark:bg-orange-900/50', text: 'text-orange-600 dark:text-orange-400' },
    teal:   { bg: 'bg-teal-100 dark:bg-teal-900/50',     text: 'text-teal-600 dark:text-teal-400' },
    red:    { bg: 'bg-red-100 dark:bg-red-900/50',       text: 'text-red-600 dark:text-red-400' },
} %}

{% set colors = color_map[icon_color] | default(color_map['blue']) %}
{% set tag = route is defined and route ? 'a' : 'div' %}

<{{ tag }}{% if route is defined and route %} href="{{ path(route) }}"{% endif %}
    class="flex items-center gap-4 p-4 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50 {{ route is defined and route ? 'hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-colors' : '' }}">
    <div class="w-10 h-10 {{ colors.bg }} rounded-lg flex items-center justify-center flex-shrink-0">
        {{ ux_icon(icon, {class: 'w-5 h-5 ' ~ colors.text}) }}
    </div>
    <div class="min-w-0">
        <p class="text-2xl font-bold text-gray-900 dark:text-gray-100">{{ value|number_format }}</p>
        <p class="text-sm text-gray-500 dark:text-gray-400 truncate">{{ label_key|trans }}</p>
    </div>
</{{ tag }}>
